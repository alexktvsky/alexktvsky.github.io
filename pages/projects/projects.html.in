<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="./css/reset.css" rel="stylesheet" type="text/css">
    <link href="./css/style.css" rel="stylesheet" type="text/css">
    <title>
Projects | Alex Kotovsky
    </title>
</head>

<body>
    <div class="container"
         style="display: flex;
                flex-direction: column;

                margin-left: auto;
                margin-right: auto;">

                                <!-- HEADER -->
<!-- -------------------------------------------------------------------- -->
        <div class="header"
             style="display: flex;
                    flex-direction: row;">

            <div class="picture__block"
                 style="display: flex;">

                <!-- CAT IMAGE IN HEADER -->
                <img src="img/cat.png"
                     alt="cat"
                     class="picture__size"
                     style="margin: auto;">
            </div>

            <!-- FULL NAME IN HEADER -->
            <div class="text__block">
                <div class="name__block"
                     style="display: flex;
                            flex-direction: column;
                            justify-content: flex-end;">

                    <span class="name__span">
Alex Kotovsky
                    </span>
                </div>

                <!-- NAVIGATION MENU -->
                <nav class="navigation__block"
                     style="display:flex;
                            justify-content: start;
                            margin-left: auto;
                            margin-right: auto;">

                    <a href="index.html" class="a__nav">
About
                    </a>

                    <a href="projects.html" class="a__nav">
Projects
                    </a>

                    <a href="reading.html" class="a__nav">
Reading
                    </a>

                    <a href="notes.html" class="a__nav">
Notes
                    </a>

                    <a href="contacts.html" class="a__nav">
Contacts
                    </a>
                </nav>

            </div>
        </div>

<!-- STYLES FOR HEADER -->
<style type="text/css">

    /* FONTS*/
    .name__span {
        font-size: 20px;
        font-weight: bold;
    }
    .a__nav {
        font-size: 18px;
    }
    @media (max-width: 940px) {
        .name__span {
            font-size: 18px;
        }
        .a__nav {
            font-size: 16px;
        }
    }

    /* COLORS */
    .a__nav {
        color: black;
    }
    @media (max-width: 940px) {
        .header {
            background-color: #EEE;
        }
    }

    /* EFFECTS */
    .a__nav:hover:nth-child(1) {
        border-bottom: 2px solid #00BFFF;
    }
    .a__nav:nth-child(2) {
        border-bottom: 2px solid #FF00FF;
    }
    .a__nav:hover:nth-child(3) {
        border-bottom: 2px solid #FFA500;
    }
    .a__nav:hover:nth-child(4) {
        border-bottom: 2px solid #66CDAA;
    }
    .a__nav:hover:nth-child(5) {
        border-bottom: 2px solid #9932CC;
    }

    /* MARGINS */
    .name__span {
        margin-bottom: 15px;
    }
    .navigation__block {
        margin-top: 10px;
    }
    .a__nav {
        margin-right: 30px;
    }
    @media (max-width: 940px) {
        .picture__block {
            margin-top: 10px;
        }
        .text__block {
            margin-left: 7px;
        }
        .name__block {
            margin-top: 10px;
        }
        .a__nav {
            margin-right: 20px;
        }
    }

</style>
<!-- --------------------------------------------------------------------- -->

                                <!-- MAIN -->
<!-- -------------------------------------------------------------------- -->
        <div class="main"
             style="display: flex;
                    flex-direction: column;">

            <div class="main__title">
                <span class="main__title__text">
Open source projects
                </span>
            </div>
${projects}
        </div>


<!-- STYLES FOR PROJECT PAGE -> MAIN -->
<style type="text/css">

    /* FONTS*/
    .main__title__text {
        font-size: 40px;
        font-weight: bold;
    }
    .progect__name {
        font-size: 20px;
    }
    .description__text {
        line-height: 1.6;
    }

    /* COLORS */
    .button {
        color: black;
    }
    .project__card {
        background-color: white;
    }
    .button__template {
        background-color: #eee;
    }
    .progect__name {
        color: #252525;
    }
    .description__text {
        color: #666;
    }

    /* EFFECTS */
    .project__card {
        border: 2px solid #ddd;
        border-radius: 10px;
    }
    .button__template {
        border: 1px solid #ddd;
        border-radius: 5px;
    }

    /* MARGIN AND PADDING */
    .main__title {
        margin-top: 40px;
    }
    .project__card {
        margin-top: 20px;
    }
    .button {
        padding: 3px;
    }
    .link__icon {
        margin-top: 5px;
        margin-left: 6px;
    }
    .button__template {
        padding-left: 5px;
        padding-right: 5px;

        margin-right: 10px;
    }
    @media (max-width: 940px) {
        .main__title {
            margin-left: 10px;
        }
    }
</style>
<!-- -------------------------------------------------------------------- -->

                                <!-- FOOTER -->
<!-- -------------------------------------------------------------------- -->
        <div class="footer" style="height: 50px;"></div>
<!-- -------------------------------------------------------------------- -->
    </div>
</body>
</html>
